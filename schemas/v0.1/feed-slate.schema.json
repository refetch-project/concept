{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://refetch.dev/schemas/v0.1/feed-slate.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "specVersion",
    "generatedAt",
    "items",
    "coverage",
    "diversity"
  ],
  "properties": {
    "specVersion": {
      "$ref": "common.schema.json#/$defs/specVersion"
    },
    "generatedAt": {
      "$ref": "common.schema.json#/$defs/dateTime"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidateId",
          "decision"
        ],
        "properties": {
          "candidateId": {
            "$ref": "common.schema.json#/$defs/id"
          },
          "decision": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "rank",
              "score",
              "reasons"
            ],
            "properties": {
              "rank": {
                "type": "integer",
                "minimum": 1
              },
              "score": {
                "type": "number"
              },
              "reasons": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "signal",
                    "value",
                    "weight",
                    "contribution",
                    "evidenceRefs"
                  ],
                  "properties": {
                    "signal": {
                      "type": "string"
                    },
                    "value": {
                      "type": "number"
                    },
                    "weight": {
                      "type": "number"
                    },
                    "contribution": {
                      "type": "number"
                    },
                    "evidenceRefs": {
                      "type": "array",
                      "items": {
                        "$ref": "common.schema.json#/$defs/id"
                      },
                      "minItems": 1,
                      "uniqueItems": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bySourceType"
      ],
      "properties": {
        "bySourceType": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "extensions": {
          "$ref": "common.schema.json#/$defs/extensions"
        }
      }
    },
    "diversity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clustersSelected",
        "unclusteredSelected",
        "suppressedByClusterLimit"
      ],
      "properties": {
        "clustersSelected": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "unclusteredSelected": {
          "type": "integer",
          "minimum": 0
        },
        "suppressedByClusterLimit": {
          "type": "integer",
          "minimum": 0
        },
        "extensions": {
          "$ref": "common.schema.json#/$defs/extensions"
        }
      }
    },
    "extensions": {
      "$ref": "common.schema.json#/$defs/extensions"
    }
  }
}